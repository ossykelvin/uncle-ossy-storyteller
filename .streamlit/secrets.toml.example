# Streamlit Cloud secrets template.
# Copy these keys into: Manage app → Settings → Secrets (paste as TOML).
# Do NOT commit the real secrets.toml — it is gitignored.

# ── Providers ──────────────────────────────────────────────────────────
DEFAULT_PROVIDER = "openrouter"
FALLBACK_PROVIDER = "gemini"
ENABLE_OFFLINE_FALLBACK = "true"

OPENROUTER_API_KEY = "sk-or-v1-..."
OPENROUTER_BASE_URL = "https://openrouter.ai/api/v1"
OPENROUTER_WRITING_MODEL = "openai/gpt-4o-mini"
OPENROUTER_OUTLINE_MODEL = "openai/gpt-4o-mini"
OPENROUTER_EDITING_MODEL = "openai/gpt-4o-mini"
OPENROUTER_RESEARCH_MODEL = "openai/gpt-4o-mini"
OPENROUTER_CONTINUITY_MODEL = "openai/gpt-4o-mini"
OPENROUTER_QA_MODEL = "openai/gpt-4o-mini"
OPENROUTER_MARKETING_MODEL = "openai/gpt-4o-mini"
OPENROUTER_EXPORT_MODEL = "openai/gpt-4o-mini"

GEMINI_API_KEY = "AQ..."
GEMINI_WRITING_MODEL = "gemini-2.5-flash"
GEMINI_OUTLINE_MODEL = "gemini-2.5-flash"
GEMINI_EDITING_MODEL = "gemini-2.5-flash"
GEMINI_RESEARCH_MODEL = "gemini-2.5-flash"
GEMINI_CONTINUITY_MODEL = "gemini-2.5-flash"
GEMINI_QA_MODEL = "gemini-2.5-flash"
GEMINI_MARKETING_MODEL = "gemini-2.5-flash"
GEMINI_EXPORT_MODEL = "gemini-2.5-flash"

# ── Supabase (persistent storage + auth) ───────────────────────────────
SUPABASE_URL = "https://okkyvhkcpoyrflswatax.supabase.co"
SUPABASE_PUBLISHABLE_KEY = "sb_publishable_..."
SUPABASE_SCHEMA = "StoryTeller"

# ── Brevo (optional, transactional email) ──────────────────────────────
BREVO_API_KEY = "xkeysib-..."
